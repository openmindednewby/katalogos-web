{
  "name": "katalogos-web",
  "version": "0.1.0",
  "description": "Katalogos — online menus platform",
  "main": "expo-router/entry",
  "scripts": {
    "start": "powershell ./scripts/set-environment.ps1 -Environment dev",
    "start:dev": "powershell ./scripts/set-environment.ps1 -Environment dev",
    "start:test": "powershell ./scripts/set-environment.ps1 -Environment test",
    "start:prod": "powershell ./scripts/set-environment.ps1 -Environment prod",
    "web": "powershell ./scripts/set-environment.ps1 -Environment dev",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:strict": "eslint . --max-warnings 0",
    "yagni": "ts-prune --ignore \"\\\\app\\\\|index.ts|index.tsx|__tests__|.test.|.spec.|\\\\server\\\\|\\\\generated\\\\|\\\\shared\\\\testIds|\\\\shared\\\\types|\\\\packages\\\\|\\\\dist\\\\|.config.\"",
    "yagni:ci": "ts-prune --error --ignore \"\\\\app\\\\|index.ts|index.tsx|__tests__|.test.|.spec.|\\\\server\\\\|\\\\generated\\\\|\\\\shared\\\\testIds|\\\\shared\\\\types|\\\\packages\\\\|\\\\dist\\\\|.config.\"",
    "postinstall": "node -e \"require('fs').mkdirSync('node_modules/@tybys/wasm-util/lib/cjs/wasi',{recursive:true})\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "jest --maxWorkers=4 --workerIdleMemoryLimit=512MB",
    "test:watch": "jest --watch --maxWorkers=4 --workerIdleMemoryLimit=512MB",
    "test:coverage": "jest --coverage --maxWorkers=4 --workerIdleMemoryLimit=512MB",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "generate:api": "node ./scripts/generate-api.js",
    "generate:hooks": "powershell ./scripts/Generate-ApiHooks.ps1",
    "generate:hooks:skip-download": "powershell ./scripts/Generate-ApiHooks.ps1 -SkipDownload",
    "types:openapi": "openapi-typescript %OPENAPI_URL% -o src/generated/schema.d.ts",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect",
    "lighthouse:assert": "lhci assert",
    "lighthouse:open": "npx serve lighthouse-reports -p 9001",
    "security:audit": "npm audit --audit-level=high",
    "security:audit-fix": "npm audit fix",
    "deps:outdated": "npm outdated || exit 0",
    "deps:unused": "npx depcheck --ignores=\"@types/jest,@size-limit/file,eslint-import-resolver-typescript,ajv-formats,react-native-svg,react-native-worklets,expo-status-bar\"",
    "deps:licenses": "npx license-checker --onlyAllow \"MIT;Apache-2.0;Apache 2.0;ISC;BSD;BSD-2-Clause;BSD-3-Clause;0BSD;Unlicense;UNLICENSED;CC0-1.0;CC-BY-3.0;CC-BY-4.0;Python-2.0;BlueOak-1.0.0;MPL-2.0;UNKNOWN\"",
    "deps:bundle-size": "npx size-limit",
    "deps:health": "npm run deps:outdated && npm run deps:unused",
    "deps:all": "npm run security:audit && npm run deps:health && npm run deps:licenses"
  },
  "dependencies": {
    "@baseclient/core": "file:./packages/core",
    "@baseclient/identity-module": "file:./packages/identity-module",
    "@baseclient/onlinemenu-module": "file:./packages/onlinemenu-module",
    "@baseclient/questioner-module": "file:./packages/questioner-module",
    "@baseclient/tenant-theme-editor-module": "file:./packages/tenant-theme-editor-module",
    "@dloizides/api-client-base": "^1.0.0",
    "@dloizides/auth-client": "^3.3.0",
    "@dloizides/auth-web": "^1.4.0",
    "@dloizides/notification-client": "^1.0.5",
    "@dloizides/ui-primitives": "^1.0.1",
    "@dloizides/utils": "^1.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@onlinemenu/identity-client": "file:./packages/identity-client",
    "@react-native-community/slider": "^5.1.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/react": "^10.44.0",
    "@tanstack/react-query": "^5.90.20",
    "axios": "^1.13.4",
    "dompurify": "^3.3.3",
    "expo": "~54.0.33",
    "expo-constants": "^18.0.10",
    "expo-document-picker": "^14.0.8",
    "expo-image-picker": "^17.0.10",
    "expo-linking": "^8.0.11",
    "expo-localization": "^17.0.8",
    "expo-router": "^6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-status-bar": "~3.0.9",
    "i18next": "^25.8.4",
    "jspdf": "^4.2.0",
    "posthog-js": "^1.362.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.6",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "react-qr-code": "^2.0.18",
    "react-redux": "^9.2.0",
    "read-excel-file": "^7.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@size-limit/file": "12.0.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.13",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "ajv-formats": "^3.0.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-react-native-a11y": "^3.5.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "jsonc-eslint-parser": "^2.4.2",
    "license-checker": "^25.0.1",
    "openapi-typescript": "^7.10.1",
    "orval": "^7.21.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.2.4",
    "size-limit": "12.0.0",
    "ts-prune": "^0.10.3",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "minimatch": ">=10.2.1",
    "test-exclude": {
      "minimatch": "^3.1.2"
    },
    "eslint-plugin-import": {
      "minimatch": "^3.1.2"
    },
    "depcheck": {
      "minimatch": "^3.1.2"
    }
  }
}
